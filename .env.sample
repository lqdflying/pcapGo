# =============================================================================
# PCAP Analyzer - Production Environment Sample (template, lives in the repo)
# =============================================================================
# This is a SAMPLE — do NOT fill it with real secrets or run from it in place.
# Copy it into your deployment directory on the host and edit that copy:
#   cp .env.sample ~/pcapgo-deploy/.env
# Then fill ~/pcapgo-deploy/.env with real values and run from there:
#   cd ~/pcapgo-deploy && docker compose up -d
#
# This sample is the single source of truth for docker-compose.yml — the
# compose file injects every variable below via env_file and holds NO built-in
# defaults. Copy this file whole, then edit the secrets. Do NOT delete optional
# lines or leave numeric/boolean settings blank: an empty value is passed to the
# container as "" and will make the backend fail validation on startup.
# =============================================================================

# --- Database ---
# PostgreSQL connection string. Replace host, user, password, and database.
# For 1Panel deployments: use the PostgreSQL container/service name as the host
# because the web container joins the 1panel-network.
DATABASE_URL=postgresql+asyncpg://pcap:CHANGE_ME@postgres:5432/pcap

# --- GitHub OAuth ---
# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://YOUR_DOMAIN/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=https://YOUR_DOMAIN/auth/github/callback

# --- JWT ---
# Generate with: openssl rand -hex 32  (minimum 32 characters in production)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
# JWT cookie lifetime in minutes (1440 = 24 hours).
JWT_EXPIRE_MINUTES=1440

# --- LLM (Optional) ---
# Leave LLM_API_KEY empty to disable AI analysis.
# Works with any OpenAI-compatible endpoint: DeepSeek, Ollama, OpenRouter, etc.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# --- App ---
# The publicly accessible base URL of your deployment (used for OAuth redirects)
PUBLIC_BASE_URL=https://YOUR_DOMAIN
MAX_UPLOAD_MB=100

# --- Security knobs ---
# Mark the JWT cookie Secure. Set to false ONLY behind a TLS-terminating proxy
# when the cookie still has to make an internal hop.
COOKIE_SECURE=true

# Separate secret for OAuth state cookies (Starlette SessionMiddleware).
# Leave empty to fall back to JWT_SECRET (dev only). In production, set this
# to its own random value (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# Run with relaxed secret validation. Intended for local development and the
# test suite. NEVER enable in production.
DEV_MODE=false

# --- User Management ---
# GitHub username of the seed super admin. This user is automatically added to
# the allowed users list on startup and cannot be deleted. Required for access
# control — without it, no one can manage the user allowlist.
ADMIN_GITHUB_USER=

# --- Standalone (single-container) deployment only ---
# When true, the backend serves the built React SPA via StaticFiles.
# Must be true for docker-compose.yml (the production image bundles the SPA).
SERVE_FRONTEND=true
# Host port the standalone container exposes.
WEB_PORT=8000
