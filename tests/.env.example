# =============================================================================
# PCAP Analyzer - Test / Development Environment Configuration
# =============================================================================
# Template for the full 3-container local stack (tests/docker-compose.yml):
# PostgreSQL + FastAPI backend + nginx. Copy to .env at the project root:
#   cp tests/.env.example .env
# For production (1Panel, single container) use .env.sample instead.

# --- Database ---
# PostgreSQL connection. Use the same password as POSTGRES_PASSWORD below.
DATABASE_URL=postgresql+asyncpg://pcap:CHANGE_ME@postgres:5432/pcap
POSTGRES_PASSWORD=CHANGE_ME

# --- GitHub OAuth ---
# Create a GitHub OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://YOUR_DOMAIN/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=http://localhost/auth/github/callback

# --- JWT ---
# Generate with: openssl rand -hex 32  (minimum 32 characters in production)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# --- LLM (Optional) ---
# Leave LLM_API_KEY empty to disable AI analysis.
# Works with any OpenAI-compatible endpoint: DeepSeek, Ollama, OpenRouter, etc.
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# --- App ---
# The publicly accessible base URL of your deployment (used for OAuth redirects)
PUBLIC_BASE_URL=http://localhost
MAX_UPLOAD_MB=100

# --- GeoIP ---
# Country statistics use GeoLite2-Country.mmdb. The production image bundles one;
# local/test stacks can override this path if needed.
GEOIP_DB_PATH=data/GeoLite2-Country.mmdb
GEOIP_MAX_DB_MB=100

# --- Advanced / Optional ---
# These have sensible defaults; uncomment to override.

# JWT cookie lifetime in minutes (default 1440 = 24 hours).
# JWT_EXPIRE_MINUTES=1440

# Mark the JWT cookie Secure (default true). Set to false ONLY behind a
# TLS-terminating proxy when the cookie still has to make an internal hop.
# COOKIE_SECURE=true

# Separate secret for OAuth state cookies (Starlette SessionMiddleware).
# When unset, falls back to JWT_SECRET (dev only). In production, set this
# to its own random value (e.g. `openssl rand -hex 32`).
# SESSION_SECRET=

# Run with relaxed secret validation. Intended for local development and
# the test suite. NEVER enable in production.
# DEV_MODE=false

# --- Standalone (single-container) deployment only ---
# SERVE_FRONTEND=true
# WEB_PORT=8000

# --- Full-stack (tests/docker-compose.yml) deployment only ---
# NGINX_PORT=80
